{
	"name": "portfolio",
	"type": "module",
	"version": "0.0.4",
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"test": "bun test",
		"prepush:ci": "bun run scripts/security/prepush-ci.mjs",
		"lint": "astro check",
		"format": "prettier --write .",
		"security:check-config": "bun run scripts/security/check-bun-hardening.mjs",
		"security:check-exceptions-expiry": "bun run scripts/security/check-exceptions-expiry.mjs --warn-days 14 --enforce true",
		"security:audit": "bun audit",
		"security:enforce-osv": "bun run scripts/security/enforce-osv-policy.mjs",
		"security:enforce-audit": "bun run scripts/security/enforce-audit-policy.mjs"
	},
	"dependencies": {
		"@astrojs/check": "0.9.8",
		"@astrojs/react": "5.0.3",
		"@astrojs/sitemap": "3.7.2",
		"@astrojs/tailwind": "6.0.2",
		"@astrojs/ts-plugin": "1.10.7",
		"@tailwindcss/vite": "4.2.2",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"astro": "6.1.5",
		"babel-plugin-react-compiler": "1.0.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"lucide-react": "1.8.0",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"tailwind-merge": "3.5.0",
		"tailwindcss": "4.2.2",
		"tailwindcss-animate": "1.0.7",
		"typescript": "6.0.2"
	},
	"devDependencies": {
		"bun-types": "1.3.11",
		"eslint-plugin-react-hooks": "7.0.1",
		"prettier": "3.8.1",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "0.7.2"
	},
	"packageManager": "bun@1.3.11",
	"trustedDependencies": [
		"@tailwindcss/oxide",
		"esbuild",
		"sharp"
	]
}
